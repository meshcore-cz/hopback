service:
  name: Hopback
  # The single MeshCore network this instance serves. Shown on the homepage so
  # users know these diagnostics only cover that network. Omit name to hide it.
  # `message` optionally overrides the notice per locale; otherwise a templated
  # default using `name` is shown.
  network:
    name: Czech Republic
    url: https://meshcore.cz
    # Optional emoji flag shown next to the "Hopback" title.
    flag: 🇨🇿
    message:
      en: This instance only covers the MeshCore network in the Czech Republic.
      cs: Tato instance pokrývá pouze síť MeshCore v České Republice.
  databasePath: data/hopback.sqlite
  verbose: false
  autoReply: true
  testTtlMinutes: 20
  # Keep capturing packets for at least this many minutes after a test's first
  # packet is seen, even after it completes (captures late flood retransmissions).
  monitorWindowMinutes: 15
  # Re-send the endpoint reply as a flood if a direct-routed reply isn't ACKed
  # within this many seconds, so a stale path never loses the message. 0 disables.
  replyFloodFallbackSeconds: 8
  agentSecret: change-this-secret
  # privateKey: 128hex-private-key
  # publicKey: 64hex-public-key

coreScope:
  urls:
    - wss://analyzer.meshcore.cz
    - wss://mc.pp0.co
  nodeApiUrls:
    - https://analyzer.meshcore.cz/api/nodes?limit=2000&offset=0
    - https://mc.pp0.co/api/nodes?limit=2000&offset=0

endpoints:
  - id: kololec
    host: test.kololec.cz
    name: Kololeč
    region: Okres Litoměřice, Ústecký Kraj, Česká Republika
    publicKey: 5430101DB427C7E403D1D3C619C056C1BE969FC785ECC7B01774B5AD4BFCCA2B
    # Contact type: 1 Companion, 2 Repeater, 3 Room Server, 4 Sensor.
    type: 1
    # Required for central backend decryption/replies. Omit if the endpoint agent verifies locally.
    # Use either the original identity seed (64 hex) or a MeshCore Companion expanded key
    # (128 hex). Do not pass a 128-hex expanded key to identity-seed encoders.
    # privateKey: 128hex-private-key
    # agentId: kololec-agent
    location:
      label: Kololeč, Okres Litoměřice, Ústecký Kraj, Česká Republika
      lat: 50.478
      lon: 13.975

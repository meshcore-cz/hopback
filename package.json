{
	"name": "hopback",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:server": "go run ./cmd/hopbackd",
		"build": "npm run build:frontend:embed && npm run build:server && npm run build:agent",
		"build:frontend": "vite build",
		"build:frontend:embed": "SVELTEKIT_OUTPUT_DIR=cmd/hopbackd/frontend vite build",
		"build:agent": "go build -o bin/hopback-agent ./cmd/hopback-agent",
		"build:server": "go build -o bin/hopbackd ./cmd/hopbackd",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"agent": "go run ./cmd/hopback-agent",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"start": "./bin/hopbackd",
		"test:unit": "vitest",
		"test:go": "go test ./cmd/...",
		"test": "npm run test:unit -- --run && npm run test:go"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.3",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@lucide/svelte": "^1.21.0",
		"@types/leaflet": "^1.9.21",
		"leaflet": "^1.9.4"
	}
}

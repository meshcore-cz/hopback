HOPBACK_BACKEND_WS=ws://127.0.0.1:3000/agent
HOPBACK_AGENT_SECRET=change-this-secret
HOPBACK_ENDPOINT_ID=kololec
HOPBACK_AGENT_ID=kololec-agent

# Preferred radio backend selector:
# Existing meshcore-go daemon over Unix IPC:
MESHCORE_URI=ipc+unix://~/Library/Caches/mc/backend.sock
# Existing meshcore-go daemon over TCP IPC:
# MESHCORE_URI=ipc+tcp://127.0.0.1:1738
# Direct companion protocol via meshcore-proxy:
# MESHCORE_URI=tcp://10.0.0.30:5000

# MESHCORE_DEVICE=default-device-id

# Static frontend builds only. Leave empty when the Go backend serves the embedded UI.
# PUBLIC_HOPBACK_API_URL=https://hopback.pp0.co
# PUBLIC_HOPBACK_WS_URL=wss://hopback.pp0.co
# PUBLIC_BASE_PATH=/hopback

# Backward-compatible IPC settings are still supported when MESHCORE_URI is empty:
# MESHCORE_IPC_PATH=~/Library/Caches/mc/backend.sock
# MESHCORE_IPC_HOST=127.0.0.1
# MESHCORE_IPC_PORT=1738
